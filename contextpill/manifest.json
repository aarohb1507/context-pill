{
  "manifest_version": 3,
  "name": "ContextPill",
  "description": "Your personal context layer for any LLM.",
  "version": "1.0.0",
  "permissions": ["storage"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://grok.com/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*",
    "https://deepseek.com/*",
    "https://*.deepseek.com/*"
  ],
  "action": {
    "default_title": "ContextPill",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://grok.com/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*",
        "https://deepseek.com/*",
        "https://*.deepseek.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
